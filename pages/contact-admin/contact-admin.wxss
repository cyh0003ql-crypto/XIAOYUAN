page {
  background-color: #F5EDE0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  overflow-x: hidden;
  width: 100%;
}

.container {
  height: 100vh;
  width: 100%;
  background: #F5EDE0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 滚动区域 */
.scroll-area {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  overflow-x: hidden;
}

/* 小节标题 */
.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #A88A72;
  margin: 20rpx 0 12rpx 4rpx;
  letter-spacing: 1rpx;
}

/* 表单卡片 */
.form-card {
  background: #FFFDF9;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 3rpx 16rpx rgba(139,99,64,0.08);
  margin-bottom: 8rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.form-row-col {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 20rpx;
  min-width: 120rpx;
}

.form-row-col .form-label {
  margin-right: 0;
  margin-bottom: 14rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D2B1F;
  text-align: right;
}

.form-textarea {
  width: 100%;
  font-size: 26rpx;
  color: #3D2B1F;
  line-height: 1.7;
  min-height: 80rpx;
}

.input-ph {
  color: #CCBBAA;
}

.form-divider {
  height: 1rpx;
  background: #F0E8DC;
  margin: 0 -4rpx;
}

/* 二维码上传 */
.qr-upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 28rpx;
}

.qr-preview {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F5EDE0;
  margin-bottom: 16rpx;
}

.qr-preview-img {
  width: 100%;
  height: 100%;
}

.qr-change-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(61,43,31,0.55);
  color: #FFFFFF;
  font-size: 22rpx;
  text-align: center;
  padding: 12rpx 0;
}

.qr-upload-btn {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx dashed #D4B896;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: #FDFAF5;
}

.qr-upload-icon {
  font-size: 56rpx;
  margin-bottom: 14rpx;
}

.qr-upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 8rpx;
}

.qr-upload-sub {
  font-size: 22rpx;
  color: #A88A72;
}

.qr-tip {
  font-size: 22rpx;
  color: #CCBBAA;
  text-align: center;
}

/* 预览卡片 */
.preview-card {
  background: #FFFDF9;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 3rpx 16rpx rgba(139,99,64,0.08);
  margin-bottom: 8rpx;
}

.preview-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0E8DC;
  margin-bottom: 24rpx;
}

.preview-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #F5EDE0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.preview-icon {
  font-size: 48rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.preview-sub {
  font-size: 22rpx;
  color: #A88A72;
}

.preview-row {
  display: flex;
  align-items: flex-start;
}

.preview-row-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
}

.preview-row-label {
  font-size: 22rpx;
  color: #A88A72;
  margin-bottom: 6rpx;
}

.preview-row-val {
  font-size: 26rpx;
  color: #3D2B1F;
  font-weight: 500;
}

/* 保存按钮 */
.save-btn {
  background: linear-gradient(135deg, #C4A882 0%, #8B6340 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 30rpx 0;
  border-radius: 50rpx;
  margin: 28rpx 0 0;
  box-shadow: 0 8rpx 28rpx rgba(139,99,64,0.35);
  letter-spacing: 2rpx;
}

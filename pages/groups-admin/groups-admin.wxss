/* ==============================
   群聊管理 样式
   ============================== */
page {
  background: #F5EDE0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.page {
  min-height: 100vh;
  background: #F5EDE0;
  padding: 24rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.top-tip {
  font-size: 24rpx;
  color: #A88A72;
}

.add-btn {
  background: #3D2B1F;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
}

/* 群聊列表 */
.group-list {
  display: flex;
  flex-direction: column;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #CCBBAA;
  padding: 80rpx 0;
}

.group-card {
  background: #FFFDF9;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.08);
}

.group-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.group-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #F5EDE0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.group-info {
  flex: 1;
  min-width: 0;
}

.group-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.group-meta {
  font-size: 22rpx;
  color: #A88A72;
}

.group-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
}

.qr-btn {
  background: #F5EDE0;
  color: #8B6340;
}

.qr-set {
  background: rgba(139,99,64,0.12);
  color: #6B4A30;
}

.qr-empty {
  background: #FFF3DC;
  color: #C47F2A;
}

.del-btn {
  background: #FFF0F0;
  color: #D94F4F;
}

/* 满员标签（列表卡片） */
.group-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.full-badge {
  margin-left: 10rpx;
  background: #D94F4F;
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 满员快速切换按钮 */
.full-btn { font-size: 20rpx; padding: 10rpx 16rpx; }

.full-on {
  background: #FFF0F0;
  color: #D94F4F;
}

.full-off {
  background: #F5EDE0;
  color: #A88A72;
}

/* 新增弹窗内满员 toggle */
.full-toggle {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  margin-left: 12rpx;
}

.full-toggle-on {
  background: #D94F4F;
  color: #FFFFFF;
}

.full-toggle-off {
  background: #F5EDE0;
  color: #A88A72;
  border: 2rpx solid #E0D0C0;
}

/* ==============================
   弹窗
   ============================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-card {
  width: 640rpx;
  background: #FFFDF9;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 32rpx;
  max-height: 82vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2B1F;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-divider {
  height: 1rpx;
  background: #F0E4D0;
  margin-bottom: 20rpx;
}

.modal-notice {
  font-size: 26rpx;
  color: #7A5C3E;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.modal-error {
  font-size: 22rpx;
  color: #D94F4F;
  text-align: center;
  margin: 12rpx 0 0;
}

/* 表单 */
.mf-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F0E4D0;
  padding: 18rpx 0;
}

.mf-label {
  font-size: 26rpx;
  color: #3D2B1F;
  font-weight: 500;
  width: 72rpx;
  flex-shrink: 0;
}

.mf-input {
  flex: 1;
  font-size: 26rpx;
  color: #3D2B1F;
  padding-left: 12rpx;
}

/* 二维码上传区 */
.qr-upload-wrap {
  padding: 20rpx 0 12rpx;
  border-bottom: 1rpx solid #F0E4D0;
}

.qr-preview-area {
  width: 100%;
  height: 320rpx;
  background: #F5EDE0;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  border: 2rpx dashed #C4A882;
}

.qr-preview-img {
  width: 100%;
  height: 100%;
}

.qr-replace-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(61,43,31,0.55);
  color: #FFFFFF;
  font-size: 22rpx;
  text-align: center;
  padding: 10rpx 0;
}

.qr-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-upload-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.qr-upload-text {
  font-size: 26rpx;
  color: #A88A72;
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  margin-top: 32rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #8B6340;
  background: #F5EDE0;
  margin-right: 16rpx;
}

.modal-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: #3D2B1F;
}

.modal-btn-danger {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: #D94F4F;
}

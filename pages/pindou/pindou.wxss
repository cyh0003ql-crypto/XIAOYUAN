/* ==============================
   拼豆摆件页面样式
   ============================== */

page {
  background-color: #F5EDE0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.page-wrap {
  min-height: 100vh;
  background: #F5EDE0;
}

/* ---------- Banner ---------- */
.banner {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #EFE3D0 0%, #E8D5BC 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
  position: relative;
}

.banner-left {
  flex: 1;
}

.banner-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #3D2B1F;
  letter-spacing: 2rpx;
  margin-right: 16rpx;
}

.banner-badge {
  background: #8B6340;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.banner-sub {
  font-size: 22rpx;
  color: #7A5C3E;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

.banner-tags {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.banner-tag {
  background: rgba(139,99,64,0.12);
  color: #8B6340;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.banner-price-tag {
  background: #C8996A;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-mascot {
  font-size: 100rpx;
  margin-left: 16rpx;
  line-height: 1;
}

/* ---------- 分类导航 ---------- */
.category-row {
  display: flex;
  justify-content: space-around;
  background: #FFFDF9;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(139,99,64,0.07);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: #F5EDE0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.category-active .category-icon-wrap {
  background: #8B6340;
}

.category-active .category-name {
  color: #8B6340;
  font-weight: 600;
}

.category-emoji {
  font-size: 36rpx;
}

.category-name {
  font-size: 22rpx;
  color: #7A5C3E;
  text-align: center;
}

/* ---------- 商品区 ---------- */
.section {
  margin: 24rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2B1F;
}

.section-more {
  font-size: 24rpx;
  color: #8B6340;
}

/* 2列商品网格：用负margin+子元素padding模拟gap */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin-right: -20rpx;
}

.product-card {
  width: calc(50% - 20rpx);
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  background: #FFFDF9;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.08);
}

.product-img-wrap {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #F0E4D0 0%, #E8D5BC 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.product-emoji {
  font-size: 88rpx;
}

.like-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 32rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.product-desc {
  font-size: 20rpx;
  color: #A88A72;
  margin-bottom: 14rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #C8996A;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background: #3D2B1F;
  color: #fff;
  border-radius: 50%;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 300;
  line-height: 1;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #A88A72;
}

/* ==============================
   加入购物车弹窗
   ============================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  background: #FFFDF9;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-product-info {
  display: flex;
  align-items: center;
}

.modal-emoji {
  font-size: 64rpx;
  background: #F5EDE0;
  border-radius: 16rpx;
  padding: 10rpx;
  line-height: 1;
  margin-right: 20rpx;
}

.modal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2B1F;
}

.modal-price {
  font-size: 28rpx;
  color: #C8996A;
  font-weight: 700;
  margin-top: 4rpx;
}

.modal-close {
  font-size: 32rpx;
  color: #A88A72;
  padding: 10rpx;
}

.modal-divider {
  height: 1rpx;
  background: #F0E4D0;
  margin-bottom: 24rpx;
}

.modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.modal-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 500;
}

.count-ctrl {
  display: flex;
  align-items: center;
}

.count-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5EDE0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #3D2B1F;
  font-weight: 500;
}

.count-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D2B1F;
  min-width: 40rpx;
  text-align: center;
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.modal-remark-row {
  align-items: flex-start;
}

.modal-remark-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 500;
  margin-right: 16rpx;
  padding-top: 16rpx;
}

.remark-input {
  flex: 1;
  background: #F5EDE0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #3D2B1F;
  min-height: 72rpx;
}

.modal-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 24rpx;
  border-top: 1rpx solid #F0E4D0;
  margin-top: 8rpx;
}

.modal-total-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 600;
}

.modal-total-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #C8996A;
}

.modal-confirm-btn {
  background: #3D2B1F;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 60rpx;
  padding: 28rpx 0;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

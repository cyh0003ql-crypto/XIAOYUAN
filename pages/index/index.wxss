.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EDE0;
  overflow: hidden;
}

/* ── 导航栏 ── */
.nav-bar {
  background: #F5EDE0;
  padding-bottom: 16rpx;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 0;
  height: 88rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2B1F;
  letter-spacing: 1rpx;
}

.nav-right {
  display: flex;
  align-items: center;
}

.school-tag {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.75);
  border-radius: 30rpx;
  padding: 6rpx 14rpx;
  margin-right: 88rpx;
  box-shadow: 0 2rpx 8rpx rgba(139,99,64,0.10);
}

.school-name {
  font-size: 22rpx;
  color: #5C4033;
}

.arrow {
  font-size: 22rpx;
  color: #5C4033;
  margin-left: 6rpx;
}

/* ── 搜索框 ── */
.search-wrap {
  padding: 0 32rpx 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 50rpx;
  padding: 18rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(139,99,64,0.08);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* ── 滚动区 ── */
.scroll-area {
  flex: 1;
  overflow: hidden;
}

/* ── Banner ── */
.banner-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #C4A882 0%, #7A5230 100%);
  border-radius: 28rpx;
  padding: 48rpx 36rpx 44rpx;
  min-height: 260rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(139,99,64,0.30);
}

.banner-deco-1 {
  position: absolute;
  right: -60rpx;
  top: -70rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.banner-deco-2 {
  position: absolute;
  right: 140rpx;
  bottom: -90rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.banner-deco-3 {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.banner-text {
  flex: 1;
  position: relative;
  z-index: 1;
}

.banner-pill {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  border-radius: 20rpx;
  padding: 5rpx 18rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.92);
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.banner-title {
  font-size: 50rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.25;
  letter-spacing: 1rpx;
}

.banner-btn {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.22);
  border: 2rpx solid rgba(255,255,255,0.50);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ── 服务卡片 ── */
.service-grid {
  display: flex;
  margin: 0 24rpx 24rpx;
}

.service-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 12rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(139,99,64,0.09);
  margin-right: 16rpx;
}

.service-item:last-child {
  margin-right: 0;
}

.service-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.service-char {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -1rpx;
}

.repair-ico {
  background: linear-gradient(145deg, #E09060 0%, #A06030 100%);
  box-shadow: 0 6rpx 18rpx rgba(160,96,48,0.30);
}

.trade-ico {
  background: linear-gradient(145deg, #C8A855 0%, #8B7028 100%);
  box-shadow: 0 6rpx 18rpx rgba(139,112,40,0.28);
}

.craft-ico {
  background: linear-gradient(145deg, #A07860 0%, #6B4A38 100%);
  box-shadow: 0 6rpx 18rpx rgba(107,74,56,0.28);
}

.service-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 6rpx;
  text-align: center;
}

.service-desc {
  font-size: 20rpx;
  color: #AAA;
  text-align: center;
  line-height: 1.6;
}

.service-btn {
  background: linear-gradient(135deg, #F0E4D0 0%, #E4D0B8 100%);
  color: #8B6340;
  border-radius: 30rpx;
  padding: 10rpx 22rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

/* ── 成绩展示 ── */
.stats-section {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FBF5EE 100%);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(139,99,64,0.09);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #8B6340;
  padding-left: 14rpx;
  line-height: 1.4;
  border-radius: 3rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #8B6340;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #AAA;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* ── 评价区 ── */
.review-section {
  margin: 0 24rpx 24rpx;
}

.review-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(139,99,64,0.08);
  border-left: 5rpx solid #E8D4B8;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.stars {
  display: flex;
  margin-right: 12rpx;
}

.star {
  font-size: 28rpx;
  color: #DDD;
  margin-right: 2rpx;
}

.star-fill {
  color: #F4A92A;
}

.review-tag {
  background: #F5EDE0;
  color: #8B6340;
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.review-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.review-author {
  font-size: 23rpx;
  color: #BBB;
}

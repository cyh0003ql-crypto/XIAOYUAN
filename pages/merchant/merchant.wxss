/* ==============================
   工作台页面样式
   ============================== */

page {
  background-color: #F5EDE0;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.page-wrap {
  min-height: 100vh;
  background: #F5EDE0;
  padding: 24rpx;
}

/* ==============================
   登录页
   ============================== */
.login-section {
  text-align: center;
  padding: 80rpx 32rpx 40rpx;
}

.login-logo {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #A88A72;
}

.login-form {
  background: #FFFDF9;
  border-radius: 24rpx;
  margin: 32rpx 0 0;
  padding: 0 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.08);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.form-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 500;
  width: 80rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D2B1F;
  padding-left: 16rpx;
}

.input-placeholder {
  color: #CCBBAA;
}

.form-divider {
  height: 1rpx;
  background: #F0E4D0;
  margin: 0 -28rpx;
}

.login-error {
  font-size: 24rpx;
  color: #D94F4F;
  text-align: center;
  margin-top: 20rpx;
}

.login-btn {
  background: #3D2B1F;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  margin-top: 40rpx;
  letter-spacing: 2rpx;
}

.login-hint {
  text-align: center;
  margin-top: 28rpx;
  font-size: 22rpx;
  color: #CCBBAA;
}

/* ==============================
   已登录：顶部头
   ============================== */
.workbench-header {
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.main-header {
  background: linear-gradient(135deg, #C4A882 0%, #8B6340 100%);
}

.sub-header {
  background: linear-gradient(135deg, #B0A898 0%, #7A6E62 100%);
}

.wh-left {
  display: flex;
  align-items: center;
}

.wh-avatar {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.wh-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.wh-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.main-tag {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  border: 1rpx solid rgba(255,255,255,0.5);
}

.sub-tag {
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  border: 1rpx solid rgba(255,255,255,0.4);
}

.logout-btn {
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
}

/* ==============================
   通用卡片 Section
   ============================== */
.section-card {
  background: #FFFDF9;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(139,99,64,0.07);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
}

.add-btn {
  background: #3D2B1F;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

/* ==============================
   子账号列表
   ============================== */
.sub-empty {
  text-align: center;
  font-size: 24rpx;
  color: #CCBBAA;
  padding: 32rpx 0;
}

.sub-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5EDE0;
}

.sub-item:last-of-type {
  border-bottom: none;
}

.sub-avatar {
  font-size: 48rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.sub-info {
  flex: 1;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.sub-meta {
  font-size: 22rpx;
  color: #A88A72;
}

.sub-del-btn {
  background: #FFF0F0;
  color: #D94F4F;
  font-size: 22rpx;
  font-weight: 500;
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.sub-count-tip {
  font-size: 22rpx;
  color: #CCBBAA;
  text-align: right;
  margin-top: 16rpx;
}

/* ==============================
   功能模块网格
   ============================== */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.module-item {
  width: 48%;
  background: #F5EDE0;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.module-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.module-name {
  font-size: 24rpx;
  color: #3D2B1F;
  font-weight: 500;
}

.coming-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #E8D5BC;
  color: #8B6340;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

/* ==============================
   弹窗通用
   ============================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-card {
  width: 620rpx;
  background: #FFFDF9;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2B1F;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-divider {
  height: 1rpx;
  background: #F0E4D0;
  margin-bottom: 24rpx;
}

.modal-notice {
  font-size: 26rpx;
  color: #7A5C3E;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.modal-form-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F0E4D0;
  padding: 20rpx 0;
}

.modal-form-label {
  font-size: 26rpx;
  color: #3D2B1F;
  font-weight: 500;
  width: 72rpx;
  flex-shrink: 0;
}

.modal-form-input {
  flex: 1;
  font-size: 26rpx;
  color: #3D2B1F;
  padding-left: 12rpx;
}

.modal-error {
  font-size: 22rpx;
  color: #D94F4F;
  text-align: center;
  margin: 16rpx 0 0;
}

.modal-actions {
  display: flex;
  margin-top: 32rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #8B6340;
  background: #F5EDE0;
  margin-right: 16rpx;
}

.modal-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: #3D2B1F;
}

.modal-btn-danger {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: #D94F4F;
}

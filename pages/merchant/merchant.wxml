<view class="page-wrap">

  <!-- ========== 登录页 ========== -->
  <block wx:if="{{view === 'login'}}">
    <view class="login-section">
      <view class="login-logo">🏪</view>
      <view class="login-title">工作台登录</view>
      <view class="login-desc">请使用主账号或子账号登录</view>
    </view>

    <view class="login-form">
      <view class="form-item">
        <text class="form-label">账号</text>
        <input
          class="form-input"
          placeholder="请输入账号"
          placeholder-class="input-placeholder"
          value="{{loginUsername}}"
          bindinput="onUsernameInput"
        />
      </view>
      <view class="form-divider"></view>
      <view class="form-item">
        <text class="form-label">密码</text>
        <input
          class="form-input"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          password="{{true}}"
          value="{{loginPassword}}"
          bindinput="onPasswordInput"
        />
      </view>
    </view>

    <view class="login-error" wx:if="{{loginError}}">{{loginError}}</view>

    <view class="login-btn" bindtap="onLogin">登录</view>

    <view class="login-hint">
      <text>测试主账号：admin / admin123</text>
    </view>
  </block>

  <!-- ========== 主账号工作台 ========== -->
  <block wx:if="{{view === 'main'}}">
    <view class="workbench-header main-header">
      <view class="wh-left">
        <view class="wh-avatar">👑</view>
        <view class="wh-info">
          <view class="wh-name">{{sessionUser.name}}</view>
          <view class="wh-tag main-tag">主账号</view>
        </view>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </view>

    <!-- 子账号管理 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title">子账号管理</view>
        <view class="add-btn" bindtap="onOpenAddSub">+ 新增</view>
      </view>

      <view class="sub-empty" wx:if="{{subAccounts.length === 0}}">
        <text>暂无子账号，点击右上角新增</text>
      </view>

      <view
        class="sub-item"
        wx:for="{{subAccounts}}"
        wx:key="id"
      >
        <view class="sub-avatar">👤</view>
        <view class="sub-info">
          <view class="sub-name">{{item.name}}</view>
          <view class="sub-meta">账号：{{item.username}} · {{item.createdAt}}</view>
        </view>
        <view
          class="sub-del-btn"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          bindtap="onDeleteSubTap"
        >删除</view>
      </view>

      <view class="sub-count-tip">已创建 {{subAccounts.length}}/5 个子账号</view>
    </view>

    <!-- 功能模块 -->
    <view class="section-card">
      <view class="section-title" style="margin-bottom:24rpx;">店铺管理</view>
      <view class="module-grid">
        <view class="module-item" bindtap="goMapAdmin">
          <text class="module-icon">🗺️</text>
          <text class="module-name">地图管理</text>
        </view>
        <view class="module-item" bindtap="goGroupsAdmin">
          <text class="module-icon">💬</text>
          <text class="module-name">群聊管理</text>
        </view>
        <view class="module-item" bindtap="goContactAdmin">
          <text class="module-icon">🎧</text>
          <text class="module-name">联系我们管理</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ========== 子账号工作台 ========== -->
  <block wx:if="{{view === 'sub'}}">
    <view class="workbench-header sub-header">
      <view class="wh-left">
        <view class="wh-avatar">👤</view>
        <view class="wh-info">
          <view class="wh-name">{{sessionUser.name}}</view>
          <view class="wh-tag sub-tag">子账号</view>
        </view>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </view>

    <view class="section-card">
      <view class="section-title" style="margin-bottom:24rpx;">我的工作台</view>
      <view class="module-grid">
        <view class="module-item" data-name="待处理任务" bindtap="onModuleTap">
          <text class="module-icon">⏳</text>
          <text class="module-name">待处理任务</text>
          <view class="coming-tag">待上线</view>
        </view>
        <view class="module-item" data-name="订单处理" bindtap="onModuleTap">
          <text class="module-icon">📋</text>
          <text class="module-name">订单处理</text>
          <view class="coming-tag">待上线</view>
        </view>
        <view class="module-item" data-name="消息通知" bindtap="onModuleTap">
          <text class="module-icon">🔔</text>
          <text class="module-name">消息通知</text>
          <view class="coming-tag">待上线</view>
        </view>
        <view class="module-item" data-name="个人设置" bindtap="onModuleTap">
          <text class="module-icon">⚙️</text>
          <text class="module-name">个人设置</text>
          <view class="coming-tag">待上线</view>
        </view>
      </view>
    </view>
  </block>

  <view style="height:100rpx;"></view>
</view>

<!-- ===== 新增子账号弹窗 ===== -->
<view class="modal-mask" wx:if="{{showAddSubModal}}" bindtap="onCloseAddSub">
  <view class="modal-card" catchtap="noop">
    <view class="modal-title">新增子账号</view>
    <view class="modal-divider"></view>

    <view class="modal-form-item">
      <text class="modal-form-label">姓名</text>
      <input class="modal-form-input" placeholder="子账号姓名" bindinput="onNewSubName" value="{{newSubName}}" />
    </view>
    <view class="modal-form-item">
      <text class="modal-form-label">账号</text>
      <input class="modal-form-input" placeholder="登录账号" bindinput="onNewSubUsername" value="{{newSubUsername}}" />
    </view>
    <view class="modal-form-item">
      <text class="modal-form-label">密码</text>
      <input class="modal-form-input" placeholder="登录密码" password="{{true}}" bindinput="onNewSubPassword" value="{{newSubPassword}}" />
    </view>

    <view class="modal-error" wx:if="{{addSubError}}">{{addSubError}}</view>

    <view class="modal-actions">
      <view class="modal-btn-cancel" bindtap="onCloseAddSub">取消</view>
      <view class="modal-btn-confirm" bindtap="onConfirmAddSub">创建</view>
    </view>
  </view>
</view>

<!-- ===== 删除确认弹窗 ===== -->
<view class="modal-mask" wx:if="{{showDeleteConfirm}}" bindtap="onCancelDelete">
  <view class="modal-card" catchtap="noop">
    <view class="modal-title">删除子账号</view>
    <view class="modal-divider"></view>
    <view class="modal-notice">确定要删除子账号「{{deleteTargetName}}」吗？删除后该账号将无法登录。</view>
    <view class="modal-actions">
      <view class="modal-btn-cancel" bindtap="onCancelDelete">取消</view>
      <view class="modal-btn-danger" bindtap="onConfirmDelete">删除</view>
    </view>
  </view>
</view>

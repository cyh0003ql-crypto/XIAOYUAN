<view class="container">

  <!-- 品牌头部 -->
  <view class="brand-section">
    <view class="brand-logo">
      <text class="brand-icon">🌸</text>
    </view>
    <text class="brand-name">Petit Aura</text>
    <text class="brand-sub">广州科技职业学院 · 校园服务</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-card">
    <text class="form-title">欢迎登录</text>

    <view class="input-group">
      <view class="input-label">
        <text class="input-icon">📱</text>
        <text class="input-label-text">手机号</text>
      </view>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="input-group">
      <view class="input-label">
        <text class="input-icon">🔒</text>
        <text class="input-label-text">密码</text>
      </view>
      <view class="password-row">
        <input
          class="input-field password-input"
          password="{{!showPwd}}"
          placeholder="请输入密码（6位以上）"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <text class="eye-btn" bindtap="togglePwd">{{showPwd ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn {{canLogin ? 'active' : 'disabled'}}" bindtap="doLogin">
      <text class="login-btn-text">{{isNewUser ? '注册并登录' : '登录'}}</text>
    </view>

    <!-- 新用户提示 -->
    <view class="hint-row" wx:if="{{isNewUser}}">
      <text class="hint-text">首次使用该手机号，将自动注册账号</text>
    </view>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>

    <!-- 快速体验 -->
    <view class="guest-btn" bindtap="quickLogin">
      <text class="guest-btn-text">快速体验（游客登录）</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link">《隐私政策》</text>
  </view>

</view>

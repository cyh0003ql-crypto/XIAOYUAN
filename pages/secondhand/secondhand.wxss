.container {
  height: 100vh;
  background: #F5EDE0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #F5EDE0;
}

.back-btn {
  font-size: 56rpx;
  color: #3D2B1F;
  line-height: 1;
  padding: 0 8rpx;
  font-weight: 300;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D2B1F;
}

.more-icon {
  font-size: 36rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.scroll-area {
  flex: 1;
}

/* Banner */
.banner {
  margin: 8rpx 24rpx 24rpx;
  background: linear-gradient(135deg, #EDD9C0 0%, #C8A07A 100%);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 220rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 6rpx 24rpx rgba(139,99,64,0.18);
}

.banner-deco-1 {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(139,99,64,0.10);
}

.banner-deco-2 {
  position: absolute;
  right: 110rpx;
  bottom: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(139,99,64,0.07);
}

.banner-icon-box {
  width: 120rpx;
  height: 120rpx;
  background: rgba(139,99,64,0.16);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.banner-icon-char {
  font-size: 60rpx;
  font-weight: 800;
  color: #8B6340;
}

.banner-text {
  flex: 1;
}

.banner-slogan {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 8rpx;
}

.banner-highlight {
  color: #8B6340;
}

.banner-sub {
  font-size: 22rpx;
  color: #7A5A3A;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.banner-tags {
  display: flex;
  flex-wrap: wrap;
}

.b-tag {
  background: rgba(139,99,64,0.12);
  color: #8B6340;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

/* 区块 */
.section {
  margin: 0 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(139,99,64,0.09);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2B1F;
  border-left: 5rpx solid #8B6340;
  padding-left: 14rpx;
  border-radius: 3rpx;
  line-height: 1.4;
}

.section-more {
  font-size: 24rpx;
  color: #8B6340;
}

/* 回收服务 */
.recycle-list {
  display: flex;
  flex-direction: column;
}

.recycle-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0E8DC;
}

.recycle-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.recycle-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(145deg, #FDF5EC 0%, #EDD9C0 100%);
  border: 1rpx solid rgba(139,99,64,0.12);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.recycle-emoji {
  font-size: 40rpx;
}

.recycle-info {
  flex: 1;
}

.recycle-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.recycle-desc {
  font-size: 24rpx;
  color: #999;
}

.recycle-arrow {
  font-size: 40rpx;
  color: #CCC;
}

/* 商品网格：2列，space-between + 百分比宽度 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 3rpx 14rpx rgba(139,99,64,0.08);
}

.product-img-box {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #F5EDE0 0%, #EDD9C0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-emoji {
  font-size: 80rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D2B1F;
  padding: 12rpx 16rpx 4rpx;
}

.product-spec {
  font-size: 22rpx;
  color: #999;
  padding: 0 16rpx 8rpx;
}

.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx 16rpx;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B6340;
}

.like-btn {
  width: 48rpx;
  height: 48rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.like-icon {
  font-size: 28rpx;
  color: #CCC;
}

.like-icon.liked {
  color: #E53935;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  bottom: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #C4A882 0%, #8B6340 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 20rpx 52rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 28rpx rgba(139,99,64,0.40);
  letter-spacing: 1rpx;
}

.publish-icon {
  font-size: 36rpx;
  font-weight: 400;
  margin-right: 8rpx;
}

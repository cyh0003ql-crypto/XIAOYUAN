.container {
  height: 100vh;
  background: #F5EDE0;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #F5EDE0;
}

.back-btn {
  font-size: 56rpx;
  color: #3D2B1F;
  line-height: 1;
  padding: 0 8rpx;
  font-weight: 300;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D2B1F;
}

.more-icon {
  font-size: 36rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.scroll-area {
  flex: 1;
}

/* Banner */
.banner {
  margin: 8rpx 24rpx 24rpx;
  background: linear-gradient(135deg, #EDD9C0 0%, #C8A07A 100%);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 220rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 6rpx 24rpx rgba(139,99,64,0.18);
}

.banner-deco-1 {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(139,99,64,0.10);
}

.banner-deco-2 {
  position: absolute;
  right: 110rpx;
  bottom: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(139,99,64,0.07);
}

.banner-icon-box {
  width: 120rpx;
  height: 120rpx;
  background: rgba(139,99,64,0.16);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.banner-icon-char {
  font-size: 60rpx;
  font-weight: 800;
  color: #8B6340;
}

.banner-text {
  flex: 1;
}

.banner-slogan {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 8rpx;
}

.banner-highlight {
  color: #8B6340;
}

.banner-sub {
  font-size: 22rpx;
  color: #7A5A3A;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.banner-tags {
  display: flex;
  flex-wrap: wrap;
}

.b-tag {
  background: rgba(139,99,64,0.12);
  color: #8B6340;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.banner-right {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.banner-emoji {
  font-size: 80rpx;
}

/* 区块 */
.section {
  margin: 0 32rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.08);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2B1F;
  border-left: 5rpx solid #8B6340;
  padding-left: 14rpx;
  border-radius: 3rpx;
  line-height: 1.4;
}

/* 服务列表 */
.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0E8DC;
}

.service-item:last-child {
  border-bottom: none;
}

.service-img-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #FDF5EC 0%, #EDD9C0 100%);
  border: 1rpx solid rgba(139,99,64,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.service-emoji {
  font-size: 48rpx;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.service-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.service-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #8B6340;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}

.service-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.service-tag {
  background: #FFF5E6;
  color: #E07B2A;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
  margin-bottom: 10rpx;
}

.service-arrow {
  font-size: 40rpx;
  color: #CCC;
}

.more-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0E8DC;
}

.more-text {
  font-size: 26rpx;
  color: #8B6340;
}

/* 快捷入口：2列 */
.quick-entry {
  margin: 0 24rpx 20rpx;
  display: flex;
}

.entry-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(139,99,64,0.09);
  margin-right: 16rpx;
}

.entry-item:last-child {
  margin-right: 0;
}

.entry-ico-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.entry-ico-char {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.ent-book {
  background: linear-gradient(135deg, #C4A882 0%, #8B6340 100%);
  box-shadow: 0 4rpx 14rpx rgba(139,99,64,0.28);
}

.ent-mail {
  background: linear-gradient(135deg, #A07860 0%, #6B4A38 100%);
  box-shadow: 0 4rpx 14rpx rgba(107,74,56,0.25);
}

.entry-info {
  flex: 1;
}

.entry-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #3D2B1F;
  margin-bottom: 6rpx;
}

.entry-desc {
  font-size: 20rpx;
  color: #AAA;
  line-height: 1.4;
}

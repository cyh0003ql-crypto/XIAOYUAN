.container {
  height: 100vh;
  background: #F5EDE0;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F0E8DC;
  position: sticky;
  top: 0;
  z-index: 10;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-active {
  color: #8B6340;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #8B6340;
  border-radius: 2rpx;
}

.scroll-area {
  flex: 1;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  width: 100%;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D2B1F;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: #8B6340;
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 订单卡片 */
.order-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 auto 20rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.08);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-store {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.status-done       { color: #4CAF50; font-size: 24rpx; }
.status-processing { color: #FF9800; font-size: 24rpx; }
.status-pending    { color: #8B6340; font-size: 24rpx; }

.order-item-row {
  display: flex;
  margin-bottom: 20rpx;
}

.order-img-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #F5EDE0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.order-emoji {
  font-size: 56rpx;
}

.order-detail {
  flex: 1;
}

.order-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.order-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.order-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #8B6340;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0E8DC;
}

.order-date {
  font-size: 22rpx;
  color: #999;
}

.order-actions {
  display: flex;
}

.action-btn {
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.action-btn.primary {
  background: #8B6340;
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #F5EDE0;
  color: #8B6340;
  border: 1rpx solid #C4A882;
}

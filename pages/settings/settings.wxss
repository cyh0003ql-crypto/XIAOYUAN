.container {
  min-height: 100vh;
  background: #F5EDE0;
}

.scroll-area {
  height: 100vh;
}

/* ── 头像区域 ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: visible;
  margin-bottom: 16rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #D4B896;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #EDD9C0;
  border: 4rpx solid #D4B896;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 80rpx;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #8B6340;
  border-radius: 50%;
  border: 4rpx solid #F5EDE0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-icon {
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 22rpx;
  color: #AAA;
}

/* ── 分组标题 ── */
.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 32rpx;
  margin-bottom: 12rpx;
}

/* ── 信息卡片 ── */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(139,99,64,0.07);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F5EDE0;
  min-height: 88rpx;
  box-sizing: border-box;
}

.info-row.last {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-weight: 500;
  width: 140rpx;
  flex-shrink: 0;
}

.info-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D2B1F;
  text-align: right;
}

.info-placeholder {
  color: #BBAA99;
  font-size: 26rpx;
}

.info-value-muted {
  font-size: 28rpx;
  color: #AAA;
}

/* ── 修改密码按钮 ── */
.change-pwd-btn {
  margin: 0 24rpx 32rpx;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #8B6340;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.change-pwd-text {
  font-size: 28rpx;
  color: #8B6340;
  font-weight: 600;
}

/* ── 保存按钮 ── */
.save-btn {
  margin: 0 24rpx 20rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #C4A882 0%, #8B6340 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(139,99,64,0.3);
}

.save-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* ── 退出登录 ── */
.logout-btn {
  margin: 0 24rpx 24rpx;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.logout-btn-text {
  font-size: 28rpx;
  color: #FF4444;
  font-weight: 600;
}

<view class="container">
  <scroll-view scroll-y="true" class="scroll-area" show-scrollbar="false">

    <!-- 头像 & 昵称 -->
    <view class="avatar-section">
      <view class="avatar-wrap" bindtap="changeAvatar">
        <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" class="avatar-img" mode="aspectFill"/>
        <view wx:else class="avatar-placeholder">
          <text class="avatar-emoji">👤</text>
        </view>
        <view class="avatar-edit-badge">
          <text class="avatar-edit-icon">✏️</text>
        </view>
      </view>
      <text class="avatar-tip">点击更换头像</text>
    </view>

    <!-- 基本信息 -->
    <view class="section-title">基本信息</view>
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">昵称</text>
        <view class="info-right">
          <input
            class="info-input"
            value="{{userInfo.name}}"
            placeholder="请输入昵称"
            placeholder-class="info-placeholder"
            bindinput="onNameInput"
            maxlength="20"
          />
        </view>
      </view>
      <view class="info-row">
        <text class="info-label">手机号</text>
        <view class="info-right">
          <text class="info-value-muted">{{userInfo.phone || '游客账号'}}</text>
        </view>
      </view>
      <view class="info-row last">
        <text class="info-label">学校</text>
        <view class="info-right">
          <text class="info-value-muted">广州科技职业学院</text>
        </view>
      </view>
    </view>

    <!-- 修改密码 -->
    <view class="section-title" wx:if="{{userInfo.phone}}">账号安全</view>
    <view class="info-card" wx:if="{{userInfo.phone}}">
      <view class="info-row">
        <text class="info-label">当前密码</text>
        <input
          class="info-input"
          password="true"
          placeholder="请输入当前密码"
          placeholder-class="info-placeholder"
          value="{{oldPwd}}"
          bindinput="onOldPwdInput"
        />
      </view>
      <view class="info-row">
        <text class="info-label">新密码</text>
        <input
          class="info-input"
          password="true"
          placeholder="6位以上新密码"
          placeholder-class="info-placeholder"
          value="{{newPwd}}"
          bindinput="onNewPwdInput"
        />
      </view>
      <view class="info-row last">
        <text class="info-label">确认密码</text>
        <input
          class="info-input"
          password="true"
          placeholder="再次输入新密码"
          placeholder-class="info-placeholder"
          value="{{confirmPwd}}"
          bindinput="onConfirmPwdInput"
        />
      </view>
    </view>
    <view class="change-pwd-btn" bindtap="changePwd" wx:if="{{userInfo.phone}}">
      <text class="change-pwd-text">修改密码</text>
    </view>

    <!-- 保存按钮 -->
    <view class="save-btn" bindtap="saveProfile">
      <text class="save-btn-text">保存信息</text>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="logout">
      <text class="logout-btn-text">退出登录</text>
    </view>

    <view style="height: 80rpx;"></view>
  </scroll-view>
</view>
